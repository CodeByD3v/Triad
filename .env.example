# ── AI Core ───────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_from_aistudio

# ── AWS S3 Image Storage ───────────────────────────────────
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your-bucket-name

# ── Email (Gmail SMTP) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_16char_app_password
AUTHORITY_EMAIL=municipal@example.gov.in

# ── Frontend ───────────────────────────────────────────────
VITE_API_BASE=http://localhost:8000

# ── Firebase Frontend SDK (free, no billing required) ──────
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── Notes ──────────────────────────────────────────────────
# Geocoding: uses Nominatim (free, no key needed)
# Image storage: AWS S3 (bucket policy handles public read — no ACL needed)
# Firestore auth: handled by serviceAccountKey.json in backend/ (never commit this)
